# Recommended: base64-encode the entire downloaded service-account .json file
# and paste the result here as one value. This avoids any copy/paste issues
# with newlines or quotes inside the private key.
#
# To generate it:
#   Mac/Linux:  base64 -i your-key-file.json | tr -d '\n'
#   Windows (PowerShell): [Convert]::ToBase64String([IO.File]::ReadAllBytes("your-key-file.json"))
GOOGLE_SERVICE_ACCOUNT_BASE64=

# Fallback (only used if GOOGLE_SERVICE_ACCOUNT_BASE64 isn't set):
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-bot@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The Drive folder ID the app will file dated subfolders into.
# Take this from the folder's URL: drive.google.com/drive/folders/<THIS_PART>
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# A shared passcode so only you and Alex can use the app. Pick anything —
# it's not tied to a Google account, it's just a gate on the page itself.
# Leave unset only for local dev; always set it once deployed.
APP_PASSCODE=
